<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <title>Add Product</title>
</head>
<body>
<h1>Add Product</h1>
<form th:action="@{/products/save}" th:object="${product}" method="post">
    Name: <input type="text" th:field="*{name}" required /><br/>
    Description: <input type="text" th:field="*{description}" /><br/>
    Price: <input type="number" step="0.01" th:field="*{price}" required /><br/>
    Quantity: <input type="number" th:field="*{quantity}" required /><br/>
    Category: <input type="text" th:field="*{category}" required /><br/>
    <button type="submit">Save</button>
</form>
<a href="/products">Back to Products</a>
</body>
</html>