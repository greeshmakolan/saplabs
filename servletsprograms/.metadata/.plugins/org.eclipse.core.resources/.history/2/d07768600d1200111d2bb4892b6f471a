<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <title>Edit Product</title>
</head>
<body>
<h1>Edit Product</h1>
<form th:action="@{/products/update}" th:object="${product}" method="post">
    <!-- Hidden ID is required to know which product to update -->
    <input type="hidden" th:field="*{id}" />

    Name: <input type="text" th:field="*{name}" required /><br/>
    Description: <input type="text" th:field="*{description}" /><br/>
    Price: <input type="number" step="0.01" th:field="*{price}" required /><br/>
    Quantity: <input type="number" th:field="*{quantity}" required /><br/>
    Category: <input type="text" th:field="*{category}" required /><br/><br/>

    <button type="submit">Update</button>
</form>
<a href="/products">Back to Products</a>
</body>
</html>